/**
 * Prisma schema for Phase 1 (structure only).
 * Client usage and migrations begin in Phase 2.
 *
 * Prisma 7 may prefer connection URLs in prisma.config.ts —
 * DATABASE_URL / DIRECT_URL remain documented in .env.example.
 */
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum ContactStatus {
  unread
  read
  responded
  archived
}

model ContactMessage {
  id        String        @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  status    ContactStatus @default(unread)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  @@index([email])
  @@index([status])
  @@index([createdAt])
  @@map("contact_messages")
}

enum Role {
  ADMIN
  USER
}

model Profile {
  id        String   @id // Corresponds to Supabase auth user id (UUID)
  email     String   @unique
  role      Role     @default(USER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("profiles")
}

model LoginAttempt {
  id          String   @id @default(cuid())
  ip          String
  email       String
  attemptedAt DateTime @default(now())
  success     Boolean

  @@index([ip])
  @@index([attemptedAt])
  @@map("login_attempts")
}

